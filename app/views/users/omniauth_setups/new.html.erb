<% provide(:title, "X アカウントで登録") %>
<%= render Ui::CardComponent.new(size: :sm) do %>
  <h3 class="mt-3 text-xl font-medium text-center text-slate-800 dark:text-slate-200">
    X アカウントで登録
  </h3>
  <p class="mt-2 text-sm text-center text-slate-600 dark:text-slate-400">
    このアプリで使用するユーザー名と表示名を設定してください
  </p>

  <%= form_with(model: @user, url: omniauth_setup_path) do |f| %>
    <%= render Ui::AlertComponent.new(resource: @user, inline_error_attributes: [:username, :display_name]) %>

    <%= render Form::FieldComponent.new(
      form: f,
      attribute: :username,
      required: true,
      autofocus: true,
      placeholder: "@willem",
      pattern: "@[a-zA-Z0-9_]+",
      tooltip: t("tooltips.user.username"),
      wrapper_class: "w-full mt-4"
    ) %>

    <%= render Form::FieldComponent.new(
      form: f,
      attribute: :display_name,
      required: true,
      placeholder: "Master Willem",
      wrapper_class: "mt-4"
    ) %>

    <div class="mt-6">
      <%= render Ui::ButtonComponent.new(variant: :primary, type: :submit, full_width: true) do %>
        登録を完了する
      <% end %>
    </div>
  <% end %>
<% end %>
