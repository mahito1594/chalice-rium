<% provide(:title, t("label.dungeon.register")) %>
<%= render Ui::CardComponent.new(size: :md) do %>
  <h3 class="mt-3 text-xl font-medium text-center text-gray-600 dark:text-gray-200">
    <%= t("label.dungeon.register") %>
  </h3>

  <%= form_with(model: @dungeon, class: "mt-6") do |f| %>
    <%= render Ui::AlertComponent.new(resource: @dungeon, inline_error_attributes: [:glyph, :area, :depth, :is_open, :comment]) %>

    <%= render Form::FieldComponent.new(
      form: f,
      attribute: :glyph,
      required: true,
      autofocus: true,
      placeholder: "9kv8xiyi",
      minlength: 8,
      maxlength: 8
    ) %>

    <%= render Form::FieldComponent.new(
      form: f,
      attribute: :area,
      type: :select,
      required: true,
      wrapper_class: "mt-4",
      choices: Dungeon.areas.keys.map { |area| [t("enums.dungeon.area.#{area}"), area] },
      options: { selected: "pthumeru" }
    ) %>

    <%= render Form::FieldComponent.new(
      form: f,
      attribute: :depth,
      type: :select,
      required: true,
      wrapper_class: "mt-4",
      choices: (1..5).to_a.reverse,
      options: { selected: 5 }
    ) %>

    <%= render Form::CollectionCheckboxesComponent.new(
      form: f, attribute: :rite_ids, collection: @rites,
      value_method: :id, text_method: :translated_name,
      label: t("label.dungeon.attributes.additional_rites"),
      checked: @rites.filter { |x| x.name != "sinister" }.map(&:id),
      wrapper_class: "mt-4"
    ) %>

    <%= f.fields_for :layers do |layer_form| %>
      <%= render Form::LayerFieldComponent.new(form: layer_form, wrapper_class: "mt-4") %>
    <% end %>

    <%= render Form::CheckboxComponent.new(
      form: f,
      attribute: :is_open,
      checked: true,
      wrapper_class: "mt-4"
    ) %>

    <%= render Form::FieldComponent.new(
      form: f,
      attribute: :comment,
      type: :textarea,
      wrapper_class: "mt-4"
    ) %>

    <div class="mt-6">
      <%= render Ui::ButtonComponent.new(variant: :primary, type: :submit, full_width: true) do %>
        <%= t("label.general.register") %>
      <% end %>
    </div>
  <% end %>
<% end %>
