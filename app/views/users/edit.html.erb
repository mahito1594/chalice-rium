<% provide(:title, t("label.user.profile_edit")) %>
<%= render Ui::CardComponent.new(size: :sm) do %>
  <h3 class="mt-3 text-xl font-medium text-center text-slate-800 dark:text-slate-200">
    <%= t("label.user.profile_edit") %>
  </h3>

  <%= form_with(model: @user) do |f| %>
    <%= render Ui::AlertComponent.new(resource: @user, inline_error_attributes: [:display_name, :bio]) %>

    <%= render Form::ReadOnlyFieldComponent.new(
      form: f, attribute: :username, value: @user.username, wrapper_class: "w-full mt-4"
    ) %>

    <%= render Form::FieldComponent.new(
      form: f,
      attribute: :display_name,
      required: true,
      autofocus: true,
      placeholder: "Master Willem",
      wrapper_class: "mt-4"
    ) %>

    <%= render Form::FieldComponent.new(
      form: f,
      attribute: :bio,
      type: :textarea,
      wrapper_class: "mt-4"
    ) %>

    <%# X (Twitter) - keeping prefix input pattern %>
    <div class="mt-4">
      <%= f.label :twitter_link, class: "sr-only" %>
      <div class="flex items-center">
        <p class="px-3 py-2 text-slate-500 dark:text-slate-400 bg-slate-100 dark:bg-slate-800 border dark:border-slate-800 border-r-0 rounded-l-lg">
          x.com/
        </p>
        <%= f.text_field(:twitter_link,
                         class: "block w-full px-4 py-2 text-slate-700 bg-white border border-slate-300 rounded-l-none rounded-lg dark:bg-slate-800 dark:text-slate-300 dark:border-slate-600 focus:border-blue-400 dark:focus:border-blue-300 focus:ring-blue-300/40 focus:outline-hidden focus:ring-3") %>
      </div>
    </div>

    <div class="mt-6">
      <%= render Ui::ButtonComponent.new(variant: :primary, type: :submit, full_width: true) do %>
        <%= t("label.general.update") %>
      <% end %>
    </div>
  <% end %>

  <%# X 連携セクション %>
  <div class="mt-6 border border-slate-200 dark:border-slate-700 rounded-lg p-4">
    <h4 class="text-sm font-semibold text-slate-700 dark:text-slate-300 mb-3">X (Twitter) 連携</h4>

    <% if @user.provider.present? %>
      <p class="text-sm text-slate-600 dark:text-slate-400 mb-3">X アカウントと連携済みです。</p>
      <% if @user.can_unlink_x? %>
        <%= form_tag settings_x_connection_path, method: :delete,
            data: { turbo_confirm: t("label.general.sure") } do %>
          <%= render Ui::ButtonComponent.new(variant: :outline, type: :submit, full_width: true) do %>
            X 連携を解除する
          <% end %>
        <% end %>
      <% else %>
        <p class="text-xs text-slate-500 dark:text-slate-400 mb-2">
          ※ メールアドレスとパスワードを設定すると解除できます
        </p>
        <button type="button" disabled
                class="w-full font-medium tracking-wide capitalize rounded-lg px-6 py-2.5 text-sm bg-slate-100 dark:bg-slate-700 text-slate-400 dark:text-slate-500 cursor-not-allowed opacity-60">
          X 連携を解除する
        </button>
      <% end %>
    <% else %>
      <p class="text-sm text-slate-600 dark:text-slate-400 mb-3">X アカウントと連携すると、X でログインできるようになります。</p>
      <%= form_tag omniauth_authorize_path(:user, :twitter2), data: { turbo: false } do %>
        <%= render Ui::ButtonComponent.new(variant: :primary, type: :submit, full_width: true) do %>
          𝕏 と連携する
        <% end %>
      <% end %>
    <% end %>
  </div>

  <div class="mt-4 flex justify-center">
    <%= render Ui::ButtonComponent.new(variant: :secondary, href: edit_user_registration_path, full_width: true) do %>
      <%= t("label.user.email_password_update") %>
    <% end %>
  </div>

  <div class="mt-4 flex justify-center">
    <%= render Ui::ButtonComponent.new(variant: :outline, href: user_path(@user), full_width: true) do %>
      戻る
    <% end %>
  </div>

  <%# Danger Zone %>
  <div class="mt-6 border border-red-200 dark:border-red-900 rounded-lg p-4">
    <h4 class="text-sm font-semibold text-red-700 dark:text-red-400 mb-3">Danger Zone</h4>
    <%= render Ui::ButtonComponent.new(
      variant: :danger,
      href: user_path(@user),
      full_width: true,
      data: { "turbo-method": :delete, turbo_confirm: t("label.general.sure") }
    ) do %>
      <%= t("label.user.delete") %>
    <% end %>
  </div>
<% end %>
