<!DOCTYPE html>
<html>
  <head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <style>
      body {
        margin: 0;
        padding: 0;
        background-color: #f3f4f6;
        color: #1f2937;
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      }

      a {
        color: #2563eb;
      }

      .email-shell {
        width: 100%;
        padding: 32px 16px;
        box-sizing: border-box;
      }

      .email-container {
        max-width: 640px;
        margin: 0 auto;
      }

      .email-brand {
        margin: 0 0 16px;
        font-size: 12px;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: #6b7280;
      }

      .email-card {
        background-color: #ffffff;
        border: 1px solid #e5e7eb;
        border-radius: 16px;
        padding: 32px;
        box-sizing: border-box;
      }

      .email-title {
        margin: 0 0 16px;
        font-size: 28px;
        line-height: 1.3;
        font-weight: 700;
        color: #111827;
      }

      .email-text {
        margin: 0 0 16px;
        font-size: 16px;
        line-height: 1.75;
        color: #374151;
      }

      .email-muted {
        margin: 0;
        font-size: 14px;
        line-height: 1.7;
        color: #6b7280;
      }

      .email-actions {
        margin: 32px 0;
      }

      .email-button {
        display: inline-block;
        padding: 12px 20px;
        border-radius: 10px;
        background-color: #2563eb;
        color: #ffffff !important;
        font-size: 14px;
        font-weight: 700;
        letter-spacing: 0.04em;
        text-decoration: none;
      }

      .email-footer {
        margin-top: 24px;
        padding-top: 24px;
        border-top: 1px solid #e5e7eb;
      }

      @media screen and (max-width: 640px) {
        .email-shell {
          padding: 20px 12px;
        }

        .email-card {
          padding: 24px 20px;
        }

        .email-title {
          font-size: 24px;
        }
      }
    </style>
  </head>

  <body>
    <div class="email-shell">
      <div class="email-container">
        <%= yield %>
      </div>
    </div>
  </body>
</html>
